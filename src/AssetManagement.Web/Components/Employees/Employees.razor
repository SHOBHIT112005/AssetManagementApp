@page "/employees"

@using AssetManagement.Application.Interfaces
@using AssetManagement.Domain.Entities
@using AssetManagement.Domain.Enums

@inject IEmployeeService EmployeeService
@inject NavigationManager Navigation

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Employees Dashboard</h2>
    <NavLink class="btn btn-primary" href="/employees/create">
        Create Employee +
    </NavLink>
</div>

@if (isLoading)
{
    <div class="text-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!EmployeeList.Any())
{
    <div class="empty-state shadow-sm">
        <h4>No employees found</h4>
        <p>Get started by creating a new employee.</p>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <span class="fw-bold">Employee Directory</span>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone Number</th>
                        <th>Department</th>
                        <th>Designation</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Employee employee in EmployeeList)
                    {
                        <tr>
                            <td class="align-middle fw-bold">@employee.FullName</td>
                            <td class="align-middle">@employee.Email</td>
                            <td class="align-middle">@employee.PhoneNumber</td>
                            <td class="align-middle">@employee.Department</td>
                            <td class="align-middle">@employee.Designation</td>
                            <td class="align-middle">
                                <span class="badge @(employee.Status == EmployeeStatus.Active ? "bg-success" : "bg-secondary")">
                                    @employee.Status
                                </span>
                            </td>
                            <td class="text-end">
                                @if (employee.Status == EmployeeStatus.Active)
                                {
                                    <NavLink class="btn btn-sm btn-outline-primary" href="@($"/employees/edit/{employee.Id}")">Edit</NavLink>
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeactivateEmployee(employee.Id)">Deactivate</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => ActivateEmployee(employee.Id)">Activate</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private IEnumerable<Employee> EmployeeList = Enumerable.Empty<Employee>();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        EmployeeList = await EmployeeService.GetAllEmployeesAsync();
        isLoading = false;
    }

    private async Task DeactivateEmployee(int id)
    {
        isLoading = true;
        await EmployeeService.DeactivateEmployeeAsync(id);
        EmployeeList = await EmployeeService.GetAllEmployeesAsync();
        isLoading = false;
    }

    private async Task ActivateEmployee(int id)
    {
        isLoading = true;
        await EmployeeService.ActivateEmployeeAsync(id);
        EmployeeList = await EmployeeService.GetAllEmployeesAsync();
        isLoading = false;
    }
}