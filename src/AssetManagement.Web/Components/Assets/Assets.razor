@page "/assets"
@using AssetManagement.Application.DTOs
@using AssetManagement.Application.DTOs.AssetDTOs
@using AssetManagement.Application.Interfaces
@using AssetManagement.Domain.Entities
@using AssetManagement.Domain.Enums
@inject IAssetService AssetService

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Assets Dashboard</h2>
    <NavLink class="btn btn-primary" href="/assets/create">
        Create Asset +
    </NavLink>
</div>

@if (isLoading)
{
    <div class="text-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <!-- Asset Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-2 col-sm-6 mb-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h6 class="text-muted">Total Assets</h6>
                    <h3 class="text-primary mb-0">@AssetSummary.TotalAssets</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2 col-sm-6 mb-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h6 class="text-muted">Available</h6>
                    <h3 class="text-success mb-0">@AssetSummary.AvailableAssets</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2 col-sm-6 mb-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h6 class="text-muted">Assigned</h6>
                    <h3 class="text-info mb-0">@AssetSummary.AssignedAssets</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h6 class="text-muted">Under Repair</h6>
                    <h3 class="text-warning mb-0">@AssetSummary.UnderRepairAssets</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h6 class="text-muted">Retired</h6>
                    <h3 class="text-danger mb-0">@AssetSummary.RetiredAssets</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Search Field</label>
                    <InputSelect @bind-Value="Query.SearchField" class="form-select">
                        <option value="@AssetSearchField.AssetName">Asset Name</option>
                        <option value="@AssetSearchField.SerialNumber">Serial Number</option>
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Search Term</label>
                    <InputText @bind-Value="Query.SearchTerm" placeholder="Search..." class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <InputSelect @bind-Value="Query.Status" class="form-select">
                        <option value="">All Statuses</option>
                        @foreach (AssetStatus status in AssetStatuses)
                        {
                            <option value="@status">@status</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Type</label>
                    <InputSelect @bind-Value="Query.AssetType" class="form-select">
                        <option value="">All Types</option>
                        @foreach (AssetType type in AssetTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-2 d-flex">
                    <button class="btn btn-primary w-100 me-2" @onclick="SearchFilterAsync">Filter</button>
                    <button class="btn btn-outline-secondary w-100" @onclick="ResetAsync">Reset</button>
                </div>
            </div>
        </div>
    </div>

    @if (!PagedAssets.Items.Any())
    {
        <div class="empty-state shadow-sm">
            <h4>No assets found</h4>
            <p>Try adjusting your filters or create a new asset.</p>
        </div>
    }
    else
    {
        <!-- Asset List Card -->
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-bold">Asset List</span>
                <span class="text-muted small">Showing @PagedAssets.Items.Count() of @PagedAssets.TotalCount assets</span>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>
                                <button class="btn btn-link text-decoration-none p-0 text-dark fw-bold" @onclick="() => SortAsync(AssetSortField.AssetName)">
                                    Asset Name @GetSortIcon(AssetSortField.AssetName)
                                </button>
                            </th>
                            <th>Type</th>
                            <th>Serial Number</th>
                            <th>
                                <button class="btn btn-link text-decoration-none p-0 text-dark fw-bold" @onclick="() => SortAsync(AssetSortField.PurchaseDate)">
                                    Purchase Date @GetSortIcon(AssetSortField.PurchaseDate)
                                </button>
                            </th>
                            <th>
                                <button class="btn btn-link text-decoration-none p-0 text-dark fw-bold" @onclick="() => SortAsync(AssetSortField.WarrantyExpiryDate)">
                                    Warranty Expiry @GetSortIcon(AssetSortField.WarrantyExpiryDate)
                                </button>
                            </th>
                            <th>
                                <button class="btn btn-link text-decoration-none p-0 text-dark fw-bold" @onclick="() => SortAsync(AssetSortField.Status)">
                                    Status @GetSortIcon(AssetSortField.Status)
                                </button>
                            </th>
                            <th>Condition</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Asset asset in PagedAssets.Items)
                        {
                            <tr>
                                <td class="align-middle">@asset.AssetName</td>
                                <td class="align-middle">@asset.Type</td>
                                <td class="align-middle text-muted">@asset.SerialNumber</td>
                                <td class="align-middle">@asset.PurchaseDate.ToString(format: "dd-MM-yyyy")</td>
                                <td class="align-middle">@asset.WarrantyExpiryDate.ToString(format: "dd-MM-yyyy")</td>
                                <td class="align-middle">
                                    <span class="badge @GetStatusBadgeClass(asset.Status)">@asset.Status</span>
                                </td>
                                <td class="align-middle">@asset.Condition</td>
                                <td class="text-end">
                                    <NavLink class="btn btn-sm btn-outline-primary" href="@($"/assets/edit/{asset.Id}")">Edit</NavLink>
                                    @if (asset.Status == AssetStatus.Available)
                                    {
                                        <NavLink class="btn btn-sm btn-primary ms-1" href="@($"/assets/assign/{asset.Id}")">Assign</NavLink>
                                    }
                                    else if (asset.Status == AssetStatus.Assigned)
                                    {
                                        <NavLink class="btn btn-sm btn-warning ms-1" href="@($"/assets/return/{asset.Id}")">Return</NavLink>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            @if (PagedAssets.TotalPages > 1)
            {
                <div class="card-footer bg-white d-flex justify-content-center">
                    <ul class="pagination mb-0">
                        <li class="page-item @(PagedAssets.PageNumber == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="PreviousPage">Previous</button>
                        </li>
                        <li class="page-item disabled">
                            <span class="page-link">Page @PagedAssets.PageNumber of @PagedAssets.TotalPages</span>
                        </li>
                        <li class="page-item @(PagedAssets.PageNumber == PagedAssets.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="NextPage">Next</button>
                        </li>
                    </ul>
                </div>
            }
        </div>
    }
}

@code {
    private bool isLoading = true;
    private PagedResultDto<Asset> PagedAssets { get; set; } = new PagedResultDto<Asset>();
    private AssetSummaryDto AssetSummary { get; set; } = new AssetSummaryDto();
    private AssetQueryDto Query { get; set; } = new AssetQueryDto();

    private IEnumerable<AssetStatus> AssetStatuses => Enum.GetValues<AssetStatus>();
    private IEnumerable<AssetType> AssetTypes => Enum.GetValues<AssetType>();

    private async Task LoadAssetsAsync()
    {
        PagedAssets = await AssetService.GetAllAssetsAsync(queryDto: Query);
        AssetSummary = await AssetService.GetAssetSummaryServiceAsync(queryDto: Query);
    }

    private async Task PreviousPage()
    {
        if (PagedAssets.PageNumber > 1)
        {
            isLoading = true;
            Query.PageNumber--;
            await LoadAssetsAsync();
            isLoading = false;
        }
    }

    private async Task NextPage()
    {
        if (PagedAssets.PageNumber < PagedAssets.TotalPages)
        {
            isLoading = true;
            Query.PageNumber++;
            await LoadAssetsAsync();
            isLoading = false;
        }
    }

    private async Task SearchFilterAsync()
    {
        isLoading = true;
        Query.PageNumber = 1;
        await LoadAssetsAsync();
        isLoading = false;
    }

    private async Task SortAsync(AssetSortField sortField)
    {
        isLoading = true;
        Query.PageNumber = 1;
        if (Query.SortField == sortField)
        {
            Query.SortDirection = (Query.SortDirection == SortDirection.Ascending) ? SortDirection.Descending : SortDirection.Ascending;
        }
        else
        {
            Query.SortField = sortField;
            Query.SortDirection = SortDirection.Ascending;
        }
        await LoadAssetsAsync();
        isLoading = false;
    }

    private string GetSortIcon(AssetSortField field)
    {
        if (Query.SortField == field)
        {
            return Query.SortDirection == SortDirection.Ascending ? "▲" : "▼";
        }
        return string.Empty;
    }

    private string GetStatusBadgeClass(AssetStatus status)
    {
        return status switch
        {
            AssetStatus.Available => "bg-success",
            AssetStatus.Assigned => "bg-info text-dark",
            AssetStatus.UnderRepair => "bg-warning text-dark",
            AssetStatus.Retired => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private async Task ResetAsync()
    {
        isLoading = true;
        Query = new AssetQueryDto();
        await LoadAssetsAsync();
        isLoading = false;
    }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await LoadAssetsAsync();
        isLoading = false;
    }
}
